{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "moduleResolution": "node",
    "ignoreDeprecations": "6.0",
    "strict": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "outDir": "../dist/server",
    "rootDir": ".."
  },
  "include": ["./**/*", "../types/**/*"],
  "exclude": ["../node_modules", "../app", "../components", "../hooks", "../lib"]
}
